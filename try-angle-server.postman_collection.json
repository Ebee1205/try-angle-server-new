              "path": ["api", "system", "log"]
            },
            "description": "클라이언트 로그 수신 후 RabbitMQ로 전송 (Thermal 이벤트 시뮬레이션)"
          }
        },
        {
          "name": "Search Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/system/search?start_time=1700000000000&end_time=1800000000000&service=web-client&level=WARNING&limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["api", "system", "search"],
              "query": [
                {
                  "key": "start_time",
                  "value": "1700000000000",
                  "description": "시작 시간 (ms timestamp)"
                },
                {
                  "key": "end_time",
                  "value": "1800000000000",
                  "description": "종료 시간 (ms timestamp)"
                },
                {
                  "key": "service",
                  "value": "web-client",
                  "description": "서비스명 (optional)"
                },
                {
                  "key": "level",
                  "value": "WARNING",
                  "description": "로그 레벨 (optional)"
                },
                {
                  "key": "limit",
                  "value": "100",
                  "description": "최대 조회 수"
                }
              ]
            },
            "description": "MongoDB에서 특정 시간 범위의 로그 검색"
