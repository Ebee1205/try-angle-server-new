              "mode": "raw",
              "raw": "{\n  \"name\": \"홍길동\",\n  \"nickname\": \"gildong\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"010-1234-5678\",\n  \"emailConf\": \"2\",\n  \"desc\": \"테스트 사용자\",\n  \"fileId\": null,\n  \"extra\": {},\n  \"provider\": \"email\",\n  \"providerId\": null,\n  \"role\": \"CLIENT\",\n  \"password\": \"password123!\",\n  \"passwordCheck\": \"password123!\",\n  \"agreeTerms\": true\n}",
